{
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "templates/**,model/**,src/**,config/**,params.yaml,ecg_scores.json,scores.json",
      "excludeFiles": "{artifacts/**,model/model.h5,research/**,tests/**,logs/**,.venv/**,__pycache__/**,**/*.ipynb}"
    }
  }
}
