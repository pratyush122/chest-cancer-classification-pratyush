# Flask app runtime
APP_HOST=0.0.0.0
APP_PORT=8080
INPUT_IMAGE_NAME=inputImage.jpg
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=5
PROJECT_AUTHOR=Pratyush Mishra
MAX_IMAGE_BYTES=5242880

# Model paths
MODEL_PATH=model/model.h5
TFLITE_MODEL_PATH=model/model.tflite
INFERENCE_PROFILE_PATH=model/inference_profile.json
ECG_MODEL_PATH=artifacts/ecg_training/model.h5
ECG_TFLITE_MODEL_PATH=model/ecg_model.tflite
ECG_INFERENCE_PROFILE_PATH=model/ecg_inference_profile.json
USE_TFLITE_MODEL=false
TRAINED_MODEL_PATH=artifacts/training/model.h5
TRAINING_DATA_PATH=artifacts/data_ingestion/Chest-CT-Scan-data

# Data ingestion
DATA_SOURCE_URL=https://drive.google.com/file/d/1z0mreUtRmR-P-magILsDR3T7M6IkGXtY/view?usp=sharing

# MLflow (optional)
ENABLE_MLFLOW_LOGGING=false
MLFLOW_TRACKING_URI=https://dagshub.com/<username>/<repo>.mlflow
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
